    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>To_Do_application</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
